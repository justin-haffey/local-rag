{
  "urls": "http://127.0.0.1:5198",
  "LocalRag": {
    "DataDirectory": "%LOCALAPPDATA%\\LocalRag",
    "Authentication": {
      "Token": ""
    },
    "Weaviate": {
      "Endpoint": "http://127.0.0.1:8080",
      "Collection": "RagChunk_v1",
      "ApiKey": null,
      "RequestTimeoutSeconds": 30,
      "BatchSize": 100,
      "Vectorizer": "none"
    },
    "Indexing": {
      "MaxFileBytes": 5242880,
      "MaxExpandedDocumentBytes": 52428800,
      "MaxPdfPages": 1000,
      "MaxPdfTextCharacters": 10000000,
      "EnablePdfOcr": true,
      "PdfOcrDpi": 300,
      "MaxPdfOcrPages": 100,
      "MaxPdfOcrPixelsPerPage": 20000000,
      "DebounceMilliseconds": 5000,
      "StabilityIntervalMilliseconds": 1500,
      "MaxConcurrentFiles": 4,
      "ReconciliationIntervalMinutes": 30,
      "ReconciliationLeaseDurationSeconds": 120,
      "ReconciliationLeaseRenewalSeconds": 30,
      "MaxConcurrentReconciliations": 2,
      "ReconciliationDispatchPollSeconds": 5,
      "ReconciliationHistoryLimit": 20,
      "MissingSourceCleanupGraceMinutes": 60,
      "MaxRetryAttempts": 5,
      "RetryBaseDelaySeconds": 2
    },
    "Chunking": {
      "TargetTokens": 384,
      "MaximumTokens": 480,
      "OverlapTokens": 64,
      "EnabledAdapters": [
        "csharp",
        "typescript-javascript",
        "python",
        "markdown",
        "json",
        "yaml",
        "toml",
        "xml"
      ]
    },
    "Embedding": {
      "ProfileId": "bge-small-en-v1.5-384",
      "ModelDirectory": "%LOCALAPPDATA%\\LocalRag\\models\\bge-small-en-v1.5",
      "Dimensions": 384,
      "MaximumTokens": 512,
      "TokenizerId": "bert-wordpiece-lowercase-v1",
      "QueryPrefix": "",
      "PassagePrefix": ""
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
