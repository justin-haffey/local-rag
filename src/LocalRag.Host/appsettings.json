      "MissingSourceCleanupGraceMinutes": 60,
      "MaxRetryAttempts": 5,
      "RetryBaseDelaySeconds": 2
    },
    "Chunking": {
      "TargetTokens": 384,
      "MaximumTokens": 480,
      "OverlapTokens": 64
    },
    "Embedding": {
      "ProfileId": "bge-small-en-v1.5-384",
      "ModelDirectory": "%LOCALAPPDATA%\\LocalRag\\models\\bge-small-en-v1.5",
      "Dimensions": 384,
      "MaximumTokens": 512,
      "QueryPrefix": "",
      "PassagePrefix": ""
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
